#              och thresholdar för försöka isolera korten.

#Importera nödvändiga bibliotek
import cv2
import numpy as np


BKG_THRESH = 50 
#Konstanten behovs for att preprocessorn ska fungera

def preprocess_image(image):
    #denna funktionen returnar en grayad blurrad och thresholdad
    #bild
    
    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)
    blur = cv2.GaussianBlur(gray, (5, 5), 0)
    
    img_w, img_h = np.shape(image)[:2] #Denna raden returnerar bilden som en tuple 
    bkg_level = gray[int(img_h/100)][int(img_w/2)]
    thresh_level = bkg_level + BKG_THRESH
    
    retval, thresh = cv2.threshold(blur, thresh_level, 255, cv2.THRESH_BINARY)
    #Denna raden konverterar bilden till en binär värde svart eller vitt asså
    
    return thresh


#här är programmet för att outputa bilden
#läs cameraFeed.py för kommentarer kring denna koden

#Skapa två fönster, ett med den ursprungliga bilden och en med processerade
cv2.namedWindow("CameraFeed")
cv2.namedWindow("ProcessedFeed")

vc = cv2.VideoCapture(1)

if vc.isOpened():
    rval, frame = vc.read()
else:
    rval = False
    
while rval == True:
    #processa bilden
    processed_frame = preprocess_image(frame)
    
    cv2.imshow("CameraFeed", frame) #Original
    cv2.imshow("Preprocessed", processed_frame) #Processerad bild
    
    rval, fram = vc.read()
    key = cv2.waitKey(20)
    
    if key == 27: 
        break
    
cv2.destroyAllWindows
vc.release()
    
